      "warn": 2000,
      "critical": 5000
    },
    "IDENTITY.md": {
      "ideal": 500,
      "warn": 1000,
      "critical": 3000
    },
    "TOOLS.md": {
      "ideal": 5000,
      "warn": 10000,
